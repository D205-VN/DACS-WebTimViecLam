# Runtime
NODE_ENV=development
PORT=5001
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=10000
PG_MAX_LIFETIME_SECONDS=1800

# Auth
# Use a long random value, at least 32 characters.
JWT_SECRET=replace_with_a_long_random_secret
GOOGLE_CLIENT_ID=

# AI providers
# Default Gemini path.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
CV_OUTPUT_LANGUAGE=vi

# Optional local LM Studio path.
# AI_PROVIDER=lmstudio
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_TIMEOUT_MS=120000
LMSTUDIO_MAX_TOKENS=4096
LMSTUDIO_TEMPERATURE=0.35

# Optional custom AI endpoint.
CUSTOM_AI_API_URL=

# Email / SMTP
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_TIMEOUT_MS=15000

# Daily / Jitsi meeting integrations
DAILY_API_KEY=
JITSI_SECRET=replace_with_a_long_random_jitsi_secret
JITSI_APP_ID=aptertekwork

# LiveAvatar / interview avatar
LIVEAVATAR_API_KEY=
LIVEAVATAR_API_URL=https://api.liveavatar.com
LIVEAVATAR_MODE=LITE
LIVEAVATAR_AVATAR_ID=
LIVEAVATAR_VOICE_ID=
LIVEAVATAR_CONTEXT_ID=
LIVEAVATAR_LANGUAGE=vi
LIVEAVATAR_VIDEO_ENCODING=VP8
LIVEAVATAR_VIDEO_QUALITY=medium
LIVEAVATAR_DISABLE_GREETING=true
LIVEAVATAR_IS_SANDBOX=true

# Blockchain verification
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_REQUIRED=false
EVM_RPC_URL=
EVM_PRIVATE_KEY=
EVM_CHAIN_ID=
EVM_NETWORK_NAME=Polygon Amoy
EVM_ANCHOR_ADDRESS=
EVM_EXPLORER_TX_URL=
EVM_WAIT_CONFIRMATIONS=1

# Schedulers
INTERVIEW_REMINDER_INTERVAL_MS=300000
INTERVIEW_REMINDER_LOOKAHEAD_HOURS=24
INTERVIEW_REMINDER_START_DELAY_MS=5000
JOB_ALERT_DIGEST_INTERVAL_MS=3600000
JOB_ALERT_DIGEST_LIMIT=8
JOB_ALERT_DIGEST_START_DELAY_MS=8000

# Abuse protection
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=20
UPLOAD_RATE_LIMIT_WINDOW_MS=60000
UPLOAD_RATE_LIMIT_MAX=10
